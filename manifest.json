{
  "manifest_version": 3,
  "name": "LeetCode Current Streak",
  "version": "1.0.0",
  "description": "Injects the computed current submission streak into your LeetCode profile page.",
  "permissions": [],
  "host_permissions": [
    "https://leetcode.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
